{
	"name": "@flowcraft/gcp-adapter",
	"type": "module",
	"version": "1.4.2",
	"homepage": "https://flowcraft.js.org",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"test": "./testcontainers.sh && vitest run src/*.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@google-cloud/firestore": "^8.3.0",
		"@google-cloud/pubsub": "^5.3.0",
		"flowcraft": "^2.7.1",
		"ioredis": "^5.10.0"
	},
	"devDependencies": {
		"@testcontainers/gcloud": "^11.12.0",
		"@testcontainers/redis": "^11.12.0",
		"testcontainers": "^11.12.0",
		"tsdown": "^0.21.7",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
